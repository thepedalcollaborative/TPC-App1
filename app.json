{
  "expo": {
    "name": "The Pedal Collaborative",
    "slug": "tpc-app",
    "scheme": "tpc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thepedalcollaborative.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow access to take pedal photos.",
        "NSPhotoLibraryUsageDescription": "Allow access to select pedal photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow access to save pedal photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "react-native-purchases",
        {
          "apiKey": "appl_VYQDDIBgZQgjoaTYvVnRfPYeiGu"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2BB5A0",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "betaFullAccess": false,
      "revenueCatApiKey": "appl_VYQDDIBgZQgjoaTYvVnRfPYeiGu",
      "eas": {
        "projectId": "60bb4c47-9989-4358-a40f-980e7544cdaf"
      }
    }
  }
}
